# Auth0 Configuration – safe-to-commit template
# ------------------------------------------------
# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored; this file is not.
#
# Where to find these values:
#   Auth0 Dashboard → Applications → <your app> → Settings
#
# Required for the Auth0 React SDK to initialise.

VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id_here

# Optional: set an API audience if you need Auth0 access tokens
# for a backend / resource server.
# VITE_AUTH0_AUDIENCE=https://your-api-identifier
